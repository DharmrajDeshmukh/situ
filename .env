# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection
# If using local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/project1_db
# If using MongoDB Atlas, paste your connection string above instead.

# Security Secrets (Change these to long random strings in production)
JWT_ACCESS_SECRET=super_secret_access_key_123!
JWT_REFRESH_SECRET=super_secret_refresh_key_456!

# Upload Limits
MAX_FILE_SIZE=5242880 # 5MB in bytes